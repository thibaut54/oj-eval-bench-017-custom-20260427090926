# Force LF line endings on all shell/config files committed to the repo,
# pour eviter que les checkouts Windows reintroduisent des CRLF qui cassent
# les scripts dans les containers Linux et les .env source-es par bash.
*.sh    text eol=lf
*.bash  text eol=lf
*.env   text eol=lf
*.conf  text eol=lf
*.cfg   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
Dockerfile      text eol=lf
Dockerfile.*    text eol=lf
